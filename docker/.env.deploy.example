# Generated from contracts/env.schema.yaml. Do not edit by hand.
# Run script/env/generate_examples.rb to refresh this file.

# Database
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=replace-with-a-strong-db-password
DB_NAME=poster_db
DB_SSLMODE=disable
DB_SSLROOTCERT=
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m
DB_SLOW_QUERY_THRESHOLD=250ms

# Redis
REDIS_ADDR=redis:6379
# If your Redis instance requires a password, set it here. Otherwise, leave it blank. Both situations are supported.
REDIS_PASSWORD=replace-with-a-strong-redis-password
REDIS_DB=0

# Traefik gateway
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443
TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_CERT_DOMAIN=your-domain.example
# Required only when using docker-compose.tls-letsencrypt.yml.
TRAEFIK_ACME_EMAIL=admin@your-domain.example
TRAEFIK_ACME_CA_SERVER=https://acme-v02.api.letsencrypt.org/directory
# Required only when using docker-compose.tls-manual.yml.
# This directory must contain fullchain.pem and privkey.pem.
TRAEFIK_MANUAL_CERT_DIR=./traefik/certs
TRAEFIK_RATE_LIMIT_AVERAGE=100
TRAEFIK_RATE_LIMIT_PERIOD=1s
TRAEFIK_RATE_LIMIT_BURST=200
TRAEFIK_RATE_LIMIT_REDIS_ENDPOINTS=redis:6379
TRAEFIK_RATE_LIMIT_REDIS_DB=0

# Observability stack ports
PROMETHEUS_PORT=9090
LOKI_PORT=3100
ALLOY_PORT=12345
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-grafana-password

# AI Service
AI_SERVICE_URL=http://ai-service:8000
AI_SERVICE_INTERNAL_TOKEN=replace-with-strong-ai-service-internal-token
LLM_PROVIDER_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_PROVIDER_KEY=your_llm_provider_key_here
LLM_REQUEST_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=2
LLM_STREAM_CHUNK_TIMEOUT_SECONDS=30

# Content Pipeline Service
CONTENT_PIPELINE_PORT=50051
CONTENT_PIPELINE_MEDIA_ENABLED=false
CONTENT_PIPELINE_DRAFTS_ENABLED=false
CONTENT_PIPELINE_MEDIA_RESOLVER_URL=http://backend:8080/internal/media/resolve
CONTENT_PIPELINE_INTERNAL_TOKEN=replace-with-a-strong-internal-token

# R2 object storage for editor media uploads
OBJECT_STORAGE_PROVIDER=r2
R2_ACCOUNT_ID=replace-with-r2-account-id
R2_ACCESS_KEY_ID=replace-with-r2-access-key-id
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-access-key
R2_BUCKET=replace-with-r2-bucket
R2_ENDPOINT=https://replace-with-r2-account-id.r2.cloudflarestorage.com
R2_REGION=auto
MEDIA_UPLOAD_MAX_BYTES=5242880
MEDIA_UPLOAD_URL_TTL=10m
MEDIA_DOWNLOAD_URL_TTL=5m
MEDIA_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/webp,image/gif

# App
PORT=8080
APP_ENV=production
JWT_SECRET=replace-with-a-strong-random-secret
COLLAB_TOKEN_SECRET=replace-with-a-strong-collab-token-secret
COLLAB_INTERNAL_URL=http://collab-service:8090
COLLAB_WEBSOCKET_URL_BASE=wss://your-domain.example
BACKEND_API_BASE_URL=http://backend:8080
# Standalone backend role. Docker Compose overrides this per service.
BACKEND_PROCESS_ROLE=all
BACKEND_REQUIRE_REDIS=true
BACKEND_API_REPLICAS=2
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_KEY_PREFIX=mpp:ratelimit
# Generate app/internal secrets with script/secret/gen_app_secrets.py app.
# Generate self-hosted passwords with script/secret/gen_app_secrets.py infra.
COOKIE_ENCRYPTION_KEY=replace-with-exactly-32-byte-secret
# Docker Compose defaults blank values to http://browser-worker:8081.
BROWSER_WORKER_URL=
BROWSER_WORKER_INTERNAL_TOKEN=replace-with-strong-browser-worker-internal-token
BROWSER_RUNTIME_IMAGE=mpp-browser-runtime
BROWSER_RUNTIME_NETWORK=mpp-browser-runtime
BROWSER_RUNTIME_BIND_IP=0.0.0.0
BROWSER_RUNTIME_HOST=host.docker.internal
BROWSER_SESSION_USER_CONCURRENCY_LIMIT=2
BROWSER_SESSION_TENANT_CONCURRENCY_LIMIT=10
BROWSER_WORKER_POOL_SIZE=4

# Local development only
ENABLE_MOCK_LOGIN=false
ENABLE_DEV_SEED=false

# Extension
# Comma-separated extension origins allowed to call backend APIs with cookies.
EXTENSION_ALLOWED_ORIGINS=chrome-extension://replace-with-extension-id

# X OAuth 2.0 app
X_OAUTH2_CLIENT_ID=your_x_oauth2_client_id_here
X_OAUTH2_CLIENT_SECRET=your_x_oauth2_client_secret_here
X_OAUTH2_REDIRECT_URL=https://your-domain.example/api/user/dashboard/settings/x/oauth2/callback

# Email Service (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_PASSWORD=

# Public frontend origin. Also passed into the frontend image build for SEO canonical, Open Graph, sitemap, and structured-data URLs.
FRONTEND_BASE_URL=https://your-domain.example
